   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "n = 50\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    \"receita\": rng.uniform(100, 500, size=n),\n",
    "    \"custo\": rng.uniform(50, 300, size=n),\n",
    "    \"canal\": rng.choice([\"Organico\", \"Pago\", \"Indicacao\"], size=n),\n",
    "})\n",
    "df[\"lucro\"] = df[\"receita\"] - df[\"custo\"]\n",
    "df.head(10)"
   ]
